    <!-- https://bentleyjoakes.github.io/incubator/incubator_dt#constellation -->


    <owl:NamedIndividual rdf:about="https://bentleyjoakes.github.io/incubator/incubator_dt#constellation">
        <rdf:type rdf:resource="https://bentleyjoakes.github.io/DTDF/vocab/DTDFVocab#Constellation"/>
        <base:desc>The system integrates multiple software components including an Angular frontend, Leaflet-based map visualization, Node.js backend services, PostgreSQL data storage, and machine learning prediction modules.</base:desc>
        <oml:type rdf:resource="http://opencaesar.io/oml#ConceptInstance"/>
    </owl:NamedIndividual>
    



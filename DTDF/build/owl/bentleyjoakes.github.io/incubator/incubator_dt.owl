    <owl:NamedIndividual rdf:about="https://bentleyjoakes.github.io/incubator/incubator_dt#MontrealRoadDT">
        <rdf:type rdf:resource="https://bentleyjoakes.github.io/DTDF/vocab/DTDFVocab#DigitalTwin"/>
        <DTDFVocab:multiplicity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</DTDFVocab:multiplicity>
        <DTDFVocab:purpose>monitor, visualize, and predict road network conditions and construction impacts in Montreal</DTDFVocab:purpose>
        <oml:type rdf:resource="http://opencaesar.io/oml#ConceptInstance"/>
    </owl:NamedIndividual>
    


    <!-- https://bentleyjoakes.github.io/incubator/incubator_dt#angular_frontend -->


    <owl:NamedIndividual rdf:about="https://bentleyjoakes.github.io/incubator/incubator_dt#angular_frontend">
